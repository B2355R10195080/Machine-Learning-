# Import libraries
import numpy as np
import matplotlib.pyplot as plt
from sklearn.linear_model import LinearRegression
from sklearn.preprocessing import PolynomialFeatures

# Step 1: Dataset (Hours vs Score)
X = np.array([1, 2, 3, 4, 5]).reshape(-1, 1)
y = np.array([50, 55, 65, 80, 110])  # Non-linear growth

# Step 2: Convert to Polynomial Features (degree = 2)
poly = PolynomialFeatures(degree=2)
X_poly = poly.fit_transform(X)

# Step 3: Train model
model = LinearRegression()
model.fit(X_poly, y)

# Step 4: Predict
y_pred = model.predict(X_poly)

# Step 5: Plot result
plt.scatter(X, y, color='blue', label='Actual Data')
plt.plot(X, y_pred, color='red', label='Polynomial Curve')
plt.xlabel("Hours Studied")
plt.ylabel("Score")
plt.legend()
plt.show()

# Step 6: Predict new value
new_hours = 6
new_pred = model.predict(poly.transform([[new_hours]]))
print(f"Predicted score for {new_hours} hours:", new_pred[0])
